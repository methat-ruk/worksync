# WorkSync hybrid development environment
# Copy to .env when Docker runs only infrastructure and apps run locally with pnpm.
# Do not commit real secrets.

# Application
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
PORT=4000

# Frontend public runtime/build values
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# Database
DATABASE_URL=postgresql://worksync:worksync@localhost:5433/worksync?schema=public
TEST_DATABASE_URL=postgresql://worksync:worksync@localhost:5433/worksync_test?schema=public

# Cache / Queue
REDIS_URL=redis://localhost:6379
TEST_REDIS_URL=redis://localhost:6379/1
QUEUE_PREFIX=worksync

# Authentication
JWT_ACCESS_SECRET=replace-with-local-access-secret-at-least-32-bytes
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-at-least-32-bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_TOKEN_TIMEOUT_MS=5000

# Cookies / CORS
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# Object Storage
S3_REGION=us-east-1
S3_BUCKET=worksync-local
S3_ACCESS_KEY_ID=worksync
S3_SECRET_ACCESS_KEY=worksync-local-secret
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# Email / Notifications
EMAIL_FROM=no-reply@worksync.local
EMAIL_PROVIDER=disabled
EMAIL_API_KEY=replace-if-email-enabled

# Realtime
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# Observability
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=
