{
  "name": "@worksync/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "corepack pnpm --filter @worksync/auth-policy build",
    "dev": "next dev --port 3000",
    "prebuild": "corepack pnpm --filter @worksync/auth-policy build",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "pretypecheck": "corepack pnpm --filter @worksync/auth-policy build",
    "typecheck": "tsc --noEmit",
    "pretest": "corepack pnpm --filter @worksync/auth-policy build",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "corepack pnpm --filter @worksync/auth-policy build",
    "test:e2e": "node scripts/run-e2e.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.2.2",
    "@worksync/auth-policy": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "15.5.19",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.62.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.19",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  }
}
