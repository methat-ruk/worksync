{
  "name": "@worksync/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- nest start --watch",
    "build": "nest build",
    "start": "dotenv -e .env -- node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"prisma.config.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "node --disable-warning=ExperimentalWarning --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --disable-warning=ExperimentalWarning --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --selectProjects unit",
    "test:integration": "node --disable-warning=ExperimentalWarning --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --selectProjects integration",
    "test:contract": "node --disable-warning=ExperimentalWarning --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --selectProjects contract",
    "test:security": "node --disable-warning=ExperimentalWarning --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --selectProjects security",
    "test:e2e": "node --disable-warning=ExperimentalWarning --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --selectProjects e2e",
    "prisma:generate": "dotenv -e .env.example -- prisma generate",
    "prisma:validate": "dotenv -e .env.example -- prisma validate",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status:test": "node ../../scripts/prisma-test-migration-status.cjs",
    "smoke:runtime": "node ../../scripts/smoke-backend-runtime.cjs"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/swagger": "11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@worksync/auth-policy": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-auth-library": "^10.7.0",
    "nestjs-pino": "^4.4.1",
    "pg": "^8.22.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.27",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
