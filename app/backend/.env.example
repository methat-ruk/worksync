# WorkSync backend environment example
# Copy to .env for local backend development. Do not commit real secrets.

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://worksync:worksync@localhost:5433/worksync?schema=public
TEST_DATABASE_URL=postgresql://worksync:worksync@localhost:5433/worksync_test?schema=public

# Cache / Queue
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=worksync

# Authentication
JWT_ACCESS_SECRET=replace-with-local-access-secret-at-least-32-bytes
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-at-least-32-bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
AUTH_RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_KEY_SECRET=replace-with-auth-rate-limit-secret-at-least-32-bytes
TRUST_PROXY=false

# Google OAuth
# Keep disabled for local development until a Google OAuth web client exists.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_TOKEN_TIMEOUT_MS=5000

# Cookies / CORS
# Leave blank for localhost or a single API host (host-only cookie).
# For sibling production subdomains, use their shared parent, for example
# .example.com. Never include a scheme, port, or path.
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# Object Storage
S3_REGION=us-east-1
S3_BUCKET=worksync-local
S3_ACCESS_KEY_ID=worksync
S3_SECRET_ACCESS_KEY=worksync-local-secret
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# Email / Notifications
EMAIL_FROM=no-reply@worksync.local
EMAIL_PROVIDER=disabled
EMAIL_API_KEY=replace-if-email-enabled

# Realtime
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# Observability
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=

# Testing
TEST_REDIS_URL=redis://localhost:6379/1
