# WorkSync full Docker development environment
# Copy to .env before running docker/compose.yml with docker/compose.app.yml.
# Do not commit real secrets.

# Application
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
PORT=4000

# Frontend public build values.
# These are used by the browser, so localhost is correct even in full Docker mode.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# Backend container-to-container dependency URLs
DATABASE_URL=postgresql://worksync:worksync@postgres:5432/worksync?schema=public
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000

# Host-side test URL for commands run outside containers
TEST_DATABASE_URL=postgresql://worksync:worksync@localhost:5433/worksync_test?schema=public
TEST_REDIS_URL=redis://localhost:6379/1

# Authentication
# These example values are local-only. Replace them before any shared,
# staging, production-like, or internet-exposed deployment.
JWT_ACCESS_SECRET=local-docker-access-secret-at-least-32-bytes
JWT_REFRESH_SECRET=local-docker-refresh-secret-at-least-32-bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_TOKEN_TIMEOUT_MS=5000

# Cookies / CORS
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# Object Storage
S3_REGION=us-east-1
S3_BUCKET=worksync-local
S3_ACCESS_KEY_ID=worksync
S3_SECRET_ACCESS_KEY=worksync-local-secret
S3_FORCE_PATH_STYLE=true

# Email / Notifications
EMAIL_FROM=no-reply@worksync.local
EMAIL_PROVIDER=disabled
EMAIL_API_KEY=replace-if-email-enabled

# Realtime
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# Observability
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=
