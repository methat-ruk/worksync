# WorkSync local full-stack environment example
# Copy to .env for Docker Compose or root-level local orchestration.
# Service-specific templates live in app/frontend/.env.example and app/backend/.env.example.
# Do not commit real secrets.

# Application
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
PORT=4000

# Database
DATABASE_URL=postgresql://worksync:worksync@localhost:55432/worksync?schema=public

# Cache / Queue
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=worksync

# Authentication
JWT_ACCESS_SECRET=replace-with-local-access-secret
JWT_REFRESH_SECRET=replace-with-local-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies / CORS
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# Object Storage
S3_REGION=us-east-1
S3_BUCKET=worksync-local
S3_ACCESS_KEY_ID=worksync
S3_SECRET_ACCESS_KEY=worksync-local-secret
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# Email / Notifications
EMAIL_FROM=no-reply@worksync.local
EMAIL_PROVIDER=disabled
EMAIL_API_KEY=replace-if-email-enabled

# Realtime
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# Observability
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=

# Testing
# Enables the real Prisma integration suite when reachable.
TEST_DATABASE_URL=postgresql://worksync:worksync@localhost:55432/worksync_test?schema=public
TEST_REDIS_URL=redis://localhost:6379/1
