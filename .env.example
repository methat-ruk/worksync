# WorkSync environment example index
# Do not copy this file blindly if you are choosing a specific run mode.
# Do not commit real secrets.

# Run modes:
# - Hybrid development: Docker runs only postgres, redis, and minio; apps run
#   locally with pnpm. Copy .env.local.example to .env.
# - Full Docker: Docker runs frontend, backend, postgres, redis, and minio.
#   Copy .env.docker.example to .env.

# Shared defaults shown for reference.
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# Required secrets:
# - JWT_ACCESS_SECRET and JWT_REFRESH_SECRET must both be at least 32 bytes.
# - They must be different values.
# - Replace all example secrets before using a shared, staging, or production-like environment.
JWT_ACCESS_SECRET=replace-with-local-access-secret-at-least-32-bytes
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-at-least-32-bytes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookie/domain notes:
# - Leave COOKIE_DOMAIN blank for localhost.
# - Use a shared parent such as .example.com only for sibling HTTPS subdomains.
# - Never include a scheme, port, or path.
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000

# Google OAuth is disabled by default in local development.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_TOKEN_TIMEOUT_MS=5000

# For actual values, use one of:
# - .env.local.example
# - .env.docker.example
